{
  "schema_version": "1.0",
  "project": "Gaza Food Security",
  "description": "Priority scoring matrix for distribution frequency",
  
  "weights": {
    "children_under_5": 3.0,
    "children_5_12": 2.0,
    "elderly_over_60": 2.0,
    "pregnant_women": 3.0,
    "breastfeeding_women": 3.0,
    "chronic_illness": 2.0,
    "disability": 2.5,
    "single_parent": 1.5,
    "income_below_poverty": 4.0,
    "no_income": 5.0
  },
  
  "category_thresholds": {
    "critical": {"min": 12, "max": 15, "distribution_frequency": "weekly", "extra_ration": 1.3},
    "high": {"min": 8, "max": 11, "distribution_frequency": "bi_weekly", "extra_ration": 1.15},
    "medium": {"min": 4, "max": 7, "distribution_frequency": "monthly", "extra_ration": 1.0},
    "low": {"min": 0, "max": 3, "distribution_frequency": "as_needed", "extra_ration": 0.9}
  },
  
  "base_ration_nis": {
    "adult": 200,
    "child": 150,
    "elderly": 180
  },
  
  "special_needs_bonus_nis": {
    "pregnant": 100,
    "breastfeeding": 80,
    "chronic_illness": 120
  },
  
  "formula": "base + (children*child_rate) + (elderly*elderly_rate) + (income_need) + special_needs",
  
  "examples": [
    {
      "family": {"members": 6, "children": 3, "elderly": 1, "income": 1500, "pregnant": false},
      "score": 14,
      "category": "critical",
      "monthly_allocation_nis": 200+450+180+80 = 910
    },
    {
      "family": {"members": 4, "children": 1, "elderly": 0, "income": 4000, "pregnant": false},
      "score": 2,
      "category": "low",
      "monthly_allocation_nis": 200+150 = 350
    }
  ]
}
