#!/bin/bash
# Multi-Target Daily Post Publisher
# Publishes to: MoltBook (general + 9 teams), Moltter, MoltX
# Schedule: 9x daily at 00,03,06,09,12,15,18,21 UTC

TASK_TYPE="$1"
DATE=$(date +%Y-%m-%d)
LOG_FILE="/root/.openclaw/workspace/logs/post_multi_${DATE}.log"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }

WORKSPACE="/root/.openclaw/workspace"
source "$WORKSPACE/scripts/publish_daily_post.sh" 2>/dev/null || true

# ==================== BUILD CONTENT ====================

# Load mission content (reuse existing case statement from original script)
# We'll source the content building part

# Get short content for general
SHORT_TITLE=""
